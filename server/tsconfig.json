{
    "$schema": "https://json.schemastore.org/tsconfig",
    "include": [
        "**/*.ts",
        "Config/Types/*.d.ts"
    ],
    "compilerOptions": {
        "lib": ["ES2023"],
        "module": "nodenext",
        "target": "es2022",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "node16"
    }
}